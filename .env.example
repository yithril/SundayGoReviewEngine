# ── KataGo ────────────────────────────────────────────────────────────────────
KATAGO_BINARY=/usr/local/bin/katago
KATAGO_MODEL=/opt/katago/kata1-b18c384nbt-s9996604416-d4316597426.bin.gz
KATAGO_CONFIG=/opt/katago/analysis.cfg

# Number of KataGo visits per position (higher = stronger but slower)
VISITS_STANDARD=100

# ── Supabase ──────────────────────────────────────────────────────────────────
# Use the service role key (not the anon key) — this worker bypasses RLS
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=e

# ── Resend ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
# Must be a verified sender domain in your Resend account
RESEND_FROM_EMAIL=no-reply@sundaygolessons.com

# ── App ───────────────────────────────────────────────────────────────────────
# Base URL of your Next.js app — no trailing slash
APP_BASE_URL=https://sundaygolessons.com
